

[filter_local]

; ==================== 一、需要放行的核心资源 (DIRECT) ====================
; 说明: 允许这些域名通过，以保障小说的基本阅读、福利页功能正常。
; 1.1 番茄小说福利页资源
host-suffix, bytegecko.com, direct

; 1.2 内容分发与图片 (西瓜视频内容)
host-suffix, ixigua.com, direct

; 1.3 头像与缩略图资源
host-suffix, qlogo.cn, direct

; 1.4 高德地图基础服务 (部分小说可能涉及地图展示)
host-suffix, amap.com, direct


; ==================== 二、需要拒绝的广告与分析域名 (REJECT) ====================
; 说明: 以下域名将被直接拦截，拒绝其网络请求。
; 2.1 穿山甲(Pangolin)广告SDK相关
host-suffix, pangolin-sdk-toutiao-b.com, reject
host-suffix, pangolin-sdk-toutiao.com, reject
host-suffix, pglstatp-toutiao.com, reject

; 2.2 字节跳动广告引擎
host-suffix, byteimg.com, reject
host-suffix, byteorge.com, reject
host-suffix, bytegoofy.com, reject

; 2.3 数据上报与分析
host-suffix, snssdk.com, reject
host-suffix, bytedance.com, reject
host-suffix, toutiao.com, reject
host-suffix, pstatp.com, reject
host-suffix, volcengine.com, reject ; 火山引擎，可能用于数据分析

; 2.4 广告投放与跳转
host-suffix, bdurl.net, reject
host-suffix, doubleclick.net, reject
host-suffix, googlesyndication.com, reject
host-suffix, googleadservices.com, reject
host-suffix, googletagmanager.com, reject

; 2.5 其他广告与第三方服务
host-suffix, uc.cn, reject
host-suffix, ucweb.com, reject
host-suffix, baidu.com, reject
host-suffix, quark.cn, reject
host-suffix, zjip.com, reject
host-suffix, zjurl.cn, reject


; IP地址直接拒绝 (强匹配，用于应对不依赖域名的广告请求)
ip-cidr, 49.71.37.101/32, reject
ip-cidr, 117.71.105.23/32, reject
ip-cidr, 218.94.207.205/32, reject
ip-cidr, 117.92.229.188/32, reject
ip-cidr, 101.36.166.16/32, reject
ip-cidr, 180.96.2.114/32, reject


; ==================== 三、MITM 与 Rewrite 建议 (关键) ====================
; 说明: 单纯的域名拒绝只能解决一部分问题。很多广告是动态加载的，必须通过 MitM 解密流量并修改代码。
; 在 Quantumult X 的 [mitm] 部分添加：
; hostname = *.bytedance.com, *.snssdk.com, *.byteimg.com, *.pstatp.com, *.pglstatp-toutiao.com, *.pangolin-sdk-toutiao.com

